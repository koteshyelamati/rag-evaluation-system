# RAG Evaluation System - Environment Configuration
# Copy this file: cp .env.example .env
# Never commit your real .env to version control.

# -- LLM / Embedding providers --
# Google Gemini API key (required for RAG pipeline)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API key (required for Ragas evaluation)
OPENAI_API_KEY=your-openai-api-key-here

# -- Vector store (ChromaDB) --
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=rag_docs

# -- Retrieval parameters --
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# -- Query cache --
# Max LRU entries (default: 256)
QUERY_CACHE_MAXSIZE=256
# TTL in seconds (default: 3600 = 1 hour, 0 = no expiry)
QUERY_CACHE_TTL_SECONDS=3600

# -- Observability --
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Log a warning for requests slower than this (ms), 0 to disable
SLOW_REQUEST_THRESHOLD_MS=2000
